{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "cnic": { "type": "string" },
        "dob": { "type": "string" },
        "gender": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "email": { "type": "string" },
        "password": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "object" }
      },
      "required": ["fullName", "email", "password"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "User wallet balance",
      "type": "object",
      "properties": {
        "balance": { "type": "number" },
        "currencies": { "type": "object" },
        "isLinked": { "type": "boolean" },
        "accountNumber": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["balance"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction record",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "category": { "type": "string" },
        "timestamp": { "type": "object" },
        "note": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["title", "amount", "type", "timestamp"]
    },
    "SecurityLog": {
      "title": "Security Log",
      "description": "Record of security events like login",
      "type": "object",
      "properties": {
        "timestamp": { "type": "object" },
        "event": { "type": "string" },
        "status": { "type": "string" },
        "device": { "type": "string" }
      },
      "required": ["timestamp", "event", "status"]
    },
    "Bill": {
      "title": "Bill",
      "description": "Bill payment record",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "timestamp": { "type": "object" }
      },
      "required": ["type", "amount", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{email}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/wallets/{email}": {
      "schema": "Wallet",
      "description": "User wallet balances"
    },
    "/users/{email}/transactions/{txId}": {
      "schema": "Transaction",
      "description": "User transaction history"
    },
    "/users/{email}/securityLogs/{logId}": {
      "schema": "SecurityLog",
      "description": "User security logs"
    },
    "/users/{email}/bills/{billId}": {
      "schema": "Bill",
      "description": "User bill payments"
    },
    "/users/{email}/wallets/{walletId}": {
      "schema": "Wallet",
      "description": "User linked wallets"
    }
  }
}
